# DAEDALUS v0.5 — Git Ignore

# =============================================================
# SECRETS & ENVIRONMENT — NEVER commit keys
# =============================================================
.env
*.apikey
*.key
daedalus.json
env.json

# =============================================================
# PYTHON
# =============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.Python

# =============================================================
# MODELS — downloadable, too large for git
# (Qwen base, lineage snapshots, merged adapters, judge models)
# =============================================================
models/lineage/
models/inference/
models/adapters/day_*/
models/adapters/merged_*/
models/judge_distilled/
models/*/

# Model weight file extensions (belt-and-suspenders)
*.safetensors
*.pt
*.pth
*.bin
*.gguf
*.onnx
*.ggml
*.q4_0
*.q4_k_m
*.q8_0

# =============================================================
# CHECKPOINTS — training artifacts, not source
# =============================================================
checkpoints/

# =============================================================
# MEMORY STORES — operational runtime data
# =============================================================
memory/chroma_db/
memory/episodes/
memory/reflections/
memory/shallow_queue/
scripts/memory/chroma_db/
scripts/memory/episodes/

# =============================================================
# LOGS — runtime output, not source
# =============================================================
logs/*.jsonl
logs/*.log
*.log

# =============================================================
# COMPILED / CACHE
# =============================================================
unsloth_compiled_cache/
.cache/
*.cache

# =============================================================
# AUTO-GENERATED / MACHINE-SPECIFIC
# =============================================================
config/.constitutional_core.sha256

# =============================================================
# IDE
# =============================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
