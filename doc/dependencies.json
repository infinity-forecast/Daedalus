  "install_sequence": {
    "description": "Recommended installation order to avoid dependency conflicts",
    "steps": [
      {
        "step": 1,
        "action": "Create dedicated Python 3.11 conda environment",
        "command": "conda create -n daedalus-env python=3.11 -y && conda activate daedalus-env"
      },
      {
        "step": 2,
        "action": "Install PyTorch with CUDA 12.8 support",
        "command": "pip install torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu128",
        "notes": "Match the CUDA version already on your system (cu128)"
      },
      {
        "step": 3,
        "action": "Install Unsloth (CUDA-specific build)",
        "command": "pip install unsloth",
        "notes": "May require extra args for your specific CUDA version — check https://github.com/unslothai/unsloth"
      },
      {
        "step": 4,
        "action": "Install remaining Python packages via pyproject.toml",
        "command": "pip install -e . && pip install bitsandbytes peft trl chromadb hdbscan anthropic FlagEmbedding"
      },
      {
        "step": 5,
        "action": "Set up API keys",
        "command": "python scripts/setup_env.py",
        "notes": "Interactive wizard. DEEPSEEK_API_KEY already present in ~/.apikey/daedalus.json. Add ANTHROPIC_API_KEY."
      },
      {
        "step": 6,
        "action": "Log in to Hugging Face Hub",
        "command": "huggingface-cli login",
        "notes": "Required to download Qwen3-14B from HuggingFace Hub"
      },
      {
        "step": 7,
        "action": "Download Qwen3-8B base model",
        "command": "huggingface-cli download Qwen/Qwen3-8B --local-dir ./models/lineage/base_v000.bf16",
        "notes": "~16 GB download. Open-weight, no access gate required."
      },
      {
        "step": 8,
        "action": "BGE-M3 embedding model (auto-downloaded)",
        "command": "python3 -c \"from sentence_transformers import SentenceTransformer; SentenceTransformer('BAAI/bge-m3'); print('BGE-M3 ready.')\"",
        "notes": "~2.2 GB. Will be cached in ~/.cache/huggingface/"
      },
      {
        "step": 9,
        "action": "Run seeding phase",
        "command": "python scripts/seed.py",
        "notes": "Carves the wood: fine-tunes Qwen3-8B on DAEDALUS seed pairs. ~30-60 min on dual Titan RTX."
      },
      {
        "step": 10,
        "action": "First morning awakening",
        "command": "python scripts/start_day.py --interactive"
      }
